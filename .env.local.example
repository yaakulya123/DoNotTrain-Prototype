# Copy this file to .env.local and fill in the values.
#
# 1. Deploy contracts/DoNotTrain.sol via Remix on Sepolia (see SETUP.md, step 4),
#    copy the deployed address here:
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# 2. Get a free Project ID from https://cloud.walletconnect.com (see SETUP.md, step 3),
#    paste it here:
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=REPLACE_ME
